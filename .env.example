# Web service
WEB_HOST=0.0.0.0
WEB_PORT=3000
WEB_HOST_PORT=3000

# Orchestrator service
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=4000
ORCHESTRATOR_HOST_PORT=4000
TASK_STORE_PATH=/data/tasks.json
COMMAND_TIMEOUT_MS=20000
MODEL_GATEWAY_TIMEOUT_MS=30000
MAX_TASK_COMMANDS=5
MAX_CONCURRENT_TASKS=1
ALLOWED_COMMAND_PREFIXES=node,npm,echo,ls,pwd,cat
ALLOWED_WORKSPACE_ROOTS=/tmp,/app
DEFAULT_WORKING_DIRECTORY=/tmp
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_CHAT_URL=
AZURE_FOUNDRY_API_VERSION=2024-05-01-preview
MODEL_CATALOG=
MODEL_PROVIDER_OVERRIDES=
OPENAI_RESPONSES_URL=https://api.openai.com/v1/responses
ANTHROPIC_MESSAGES_URL=https://api.anthropic.com/v1/messages
GOOGLE_API_BASE=https://generativelanguage.googleapis.com/v1beta/models
ORCHESTRATOR_API_TOKEN=
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3100,http://127.0.0.1:3100,http://localhost:13100,http://127.0.0.1:13100
ALLOW_INSECURE_MARKETPLACE_HTTP=false

# Internal service wiring
ORCHESTRATOR_URL=http://orchestrator:4000

# Optional Cloudflare tunnel token (used only with tunnel profile)
TUNNEL_TOKEN=

# Comma-separated model aliases exposed by the MVP API
DEFAULT_MODELS=gpt-4.1-mini,claude-sonnet,gemini-2.0-flash

# Optional JSON array for explicit model-provider mapping.
# Example:
# MODEL_CATALOG=[{"id":"gpt-4.1-mini","provider":"openai","label":"GPT-4.1 Mini"},{"id":"claude-sonnet","provider":"anthropic"},{"id":"gemini-2.0-flash","provider":"google"},{"id":"azure/gpt-4o-mini","provider":"azure","label":"Foundry GPT-4o Mini"}]
